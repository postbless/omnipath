# OmniPath Environment Variables
# Скопируйте этот файл в .env.local и заполните значениями

# ============================================
# ОБЯЗАТЕЛЬНЫЕ КЛЮЧИ
# ============================================

# Etherscan API Key (данные о газе Ethereum)
# Получить: https://etherscan.io/apis
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Li.Fi API Key (агрегация мостов)
# Получить: https://li.fi/
VITE_LIFI_API_KEY=your_lifi_api_key_here

# WalletConnect Project ID (подключение кошелька)
# Получить: https://cloud.walletconnect.com
VITE_WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ============================================
# ОПЦИОНАЛЬНЫЕ КЛЮЧИ
# ============================================

# Coingecko API Key (цены криптовалют)
# Получить: https://coingecko.com/api/pricing
VITE_COINGECKO_API_KEY=your_coingecko_api_key_here

# Moralis API Key (данные блокчейна)
# Получить: https://moralis.io/
VITE_MORALIS_API_KEY=your_moralis_api_key_here

# Arbiscan API Key (данные о газе Arbitrum)
# Получить: https://arbiscan.io/apis
VITE_ARBISCAN_API_KEY=your_arbiscan_api_key_here

# Optimism API Key (данные о газе Optimism)
# Получить: https://optimistic.etherscan.io/apis
VITE_OPTIMISM_API_KEY=your_optimism_api_key_here

# PolygonScan API Key (данные о газе Polygon)
# Получить: https://polygonscan.com/apis
VITE_POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ============================================
# НАСТРОЙКИ
# ============================================

# Режим разработки (true) или продакшен (false)
VITE_DEV_MODE=true

# Интервал обновления данных (мс)
VITE_REFRESH_INTERVAL=30000
